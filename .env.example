# Optional: Node / pool (see readme for defaults)
# NODE_ENV=development
# DATABASE_POOL_MAX=10

# Postgres
# POSTGRES_DB=ads_platform
# POSTGRES_USER=ads_admin
# POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
# DATABASE_URL=postgresql://username:password@postgres:5432/database_name

# Redis: realtime dashboard (/api/realtime/*) + optional per-IP rate limit on POST /api/extension/ad-block
# Without REDIS_URL, ad-block rate limiting is disabled (requests still succeed).
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://redis:6379

# Better Auth (required for login)
BETTER_AUTH_SECRET=your-super-secret-at-least-32-characters-long
# Base URL for the app; also used as default API host for extension integration tests when enabled via EXTENSION_INTEGRATION=1.
# Optional: EXTENSION_INTEGRATION_BASE_URL overrides the test target when it differs from auth.
BETTER_AUTH_BASE_URL=http://localhost:3000
DOMAIN=localhost
# EXTENSION_INTEGRATION=1  # set when running pnpm test:integration (app + DB must be up)

# Optional: seed default admin when no users exist (run: npm run db:seed-admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# Anonymous / provisioned extension users: trial length in days (ad-block 403 trial_expired after end_users.end_date)
DEFAULT_TRIAL_DAYS=7

# Admin-created paid users (POST /api/end-users with plan paid): access window in calendar days when end date is omitted.
DEFAULT_PAID_SUBSCRIPTION_DAYS=30

# Extension end-user session length in days.
ENDUSER_SESSION_DAYS=12

# Optional: extension user credentials for docs/test-extension-log.sh and scripts/load-test-extension.ts (pnpm load-test:extension)
# EXTENSION_EMAIL=extension-user@example.com
# EXTENSION_PASSWORD=your-password