# Optional: Node / pool (see readme for defaults)
# NODE_ENV=development
# DATABASE_POOL_MAX=10

# Postgres
POSTGRES_DB=ads_platform
POSTGRES_USER=ads_admin
POSTGRES_PASSWORD=supers
DATABASE_URL=postgresql://ads_admin:supers@postgres:5432/ads_platform
# DATABASE_URL=postgresql://ads_admin:supersecurepassword@localhost:5432/ads_platform

# Redis (realtime + per-IP rate limits for /api/extension/ad-block, /api/extension/sync, /api/extension/live)
# Without REDIS_URL those limits are disabled; traffic is still allowed.
REDIS_URL=redis://redis:6379
# REDIS_URL=redis://localhost:6379

# Better Auth (required for login)
BETTER_AUTH_SECRET=your-super-secret-at-least-32-characters-long
# Vitest extension integration tests use this (or BETTER_AUTH_URL); optional EXTENSION_INTEGRATION_BASE_URL overrides.
BETTER_AUTH_BASE_URL=http://localhost:3000

# Optional: seed default admin when no users exist (run: npm run db:seed-admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# Anonymous / provisioned extension users: trial length in days (ad-block 403 trial_expired after end_users.end_date)
# DEFAULT_TRIAL_DAYS=7

# Admin-created paid users (POST /api/end-users with plan paid): access window in calendar days when end date is omitted
# DEFAULT_PAID_SUBSCRIPTION_DAYS=365

# Optional: extension user credentials for docs/test-extension-log.sh and scripts/load-test-extension.ts (pnpm load-test:extension)
# EXTENSION_EMAIL=extension-user@example.com
# EXTENSION_PASSWORD=your-password