{
  "name": "admin_dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:squash": "rm -f drizzle/migrations/*.sql drizzle/migrations/meta/*_snapshot.json && node -e \"require('fs').writeFileSync('drizzle/migrations/meta/_journal.json', JSON.stringify({version:'7',dialect:'postgresql',entries:[]},null,2)+'\\n')\" && pnpm db:generate",
    "db:migrate": "NODE_OPTIONS='--dns-result-order=ipv4first' drizzle-kit migrate",
    "db:migration-status": "npx tsx scripts/migration-status.ts",
    "db:migrate:app": "npx tsx scripts/apply-migrations.ts",
    "db:truncate:endusers": "npx tsx scripts/truncate-endusers-and-events.ts",
    "db:cleanup:extension-tests": "npx tsx scripts/cleanup-extension-integration-fixtures.ts",
    "db:truncate:enduser-events": "npx tsx scripts/truncate-enduser-events-and-logs.ts",
    "redis:reset-live-count": "npx tsx scripts/reset-live-count.ts",
    "db:push": "drizzle-kit push",
    "db:seed-admin": "npx tsx scripts/seed-admin.ts",
    "db:seed-target-lists": "npx tsx scripts/seed-target-lists.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:integration": "EXTENSION_INTEGRATION=1 vitest run tests/user-flow/extension/ --no-file-parallelism",
    "test:extension-v2": "EXTENSION_INTEGRATION=1 vitest run tests/user-flow/extension/extension-v2-http.integration.test.ts --no-file-parallelism",
    "test:sse-live": "EXTENSION_INTEGRATION=1 vitest run tests/user-flow/extension/extension-sse-live-connection.integration.test.ts --no-file-parallelism",
    "test:frequency-load": "EXTENSION_INTEGRATION=1 vitest run tests/user-flow/extension/extension-multi-user-frequency-load.integration.test.ts --no-file-parallelism",
    "test:unit": "vitest run tests/task-based/auth-scope.test.ts",
    "test:watch": "vitest",
    "test:extension": "vitest run tests/function-based/extension-campaign-qualify.test.ts",
    "test:extension-log": "bash docs/test-extension-log.sh",
    "load-test:extension": "npx tsx scripts/load-test-extension.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "kbar": "0.1.0-beta.48",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "recharts": "2.15.4",
    "redis": "^5.10.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.4",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
